{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/calla-faqs-hero",
  "version": "1.0.0",
  "title": "Calla FAQs Hero",
  "category": "calla-faqs",
  "icon": "heading",
  "description": "FAQs page hero with optional background image and page title.",
  "keywords": [
    "calla",
    "faq",
    "hero",
    "questions"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": "Our FAQs"
    },
    "backgroundImageUrl": {
      "type": "string",
      "default": ""
    },
    "backgroundImageId": {
      "type": "number",
      "default": 0
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}