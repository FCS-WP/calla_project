{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/calla-hero",
  "version": "1.0.0",
  "title": "Calla Hero",
  "category": "calla-home",
  "icon": "cover-image",
  "description": "Soft wellness hero section for The Calla Project homepage.",
  "keywords": [
    "calla",
    "hero",
    "wellness",
    "homepage"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "default": "Where movement meets stillness, a space to nourish, restore, and return to your natural rhythm."
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": "Explore"
    },
    "buttonUrl": {
      "type": "string",
      "default": "#"
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}