{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy-child/calla-connect-hero",
	"version": "1.0.0",
	"title": "Calla Connect Hero",
	"category": "calla-connect",
	"icon": "heading",
	"description": "Connect page hero with breadcrumb and title.",
	"keywords": ["calla", "connect", "hero", "contact"],
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"attributes": {
		"breadcrumbHomeLabel": {
			"type": "string",
			"default": "Home"
		},
		"breadcrumbHomeUrl": {
			"type": "string",
			"default": "/"
		},
		"breadcrumbCurrentLabel": {
			"type": "string",
			"default": "Connect"
		},
		"title": {
			"type": "string",
			"default": "Connect"
		},
		"backgroundImageUrl": {
			"type": "string",
			"default": ""
		},
		"backgroundImageId": {
			"type": "number",
			"default": 0
		}
	},
	"textdomain": "ai-zippy-child",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
